# Where the FastAPI server runs (Vite dev proxy). Default in vite.config.js is port 8000.
# If you get WinError 10013 on Windows when binding :8000, run uvicorn on 8080 and set:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
#
# Copy this file to .env.development and edit as needed.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
